# Required
TURSO_URL=https://your-db.aws-ap-northeast-1.turso.io
TURSO_TOKEN=your_turso_token

# Server
PORT=4211
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com   # comma-separated; * for open

# Optional — leave blank to allow unauthenticated reads (useful for same-origin dashboard)
QUERY_API_KEY=
