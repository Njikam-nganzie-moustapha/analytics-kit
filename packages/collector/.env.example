# Collector service — copy to .env and fill in values

PORT=4210
NODE_ENV=development

# Comma-separated site keys — must match X-Site-Key header from SDK
SITE_KEYS=key-yoursite123,key-othersite456

# STORAGE_BACKEND: noop | turso | telegram | composite
STORAGE_BACKEND=noop

# Turso (used when STORAGE_BACKEND=turso or composite)
TURSO_URL=https://your-db.turso.io
TURSO_TOKEN=your-turso-token

# Telegram (used when STORAGE_BACKEND=telegram or composite)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHANNEL_ID=-1001234567890

# Queue tuning
FLUSH_INTERVAL_MS=5000
MAX_QUEUE_SIZE=1000

# CORS — comma-separated origins, or omit for wildcard (development)
# CORS_ORIGINS=https://yoursite.com,https://app.yoursite.com

# Optional Redis (for multi-instance deployments — processor S3 reads from stream)
# REDIS_URL=redis://localhost:6379
