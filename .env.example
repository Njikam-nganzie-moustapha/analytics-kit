# ── Required ────────────────────────────────────────────────────────────────

# Turso cloud DB — used by processor + query-api (and collector in turso mode)
TURSO_URL=https://your-db.aws-ap-northeast-1.turso.io
TURSO_TOKEN=your_turso_token

# Comma-separated secret keys that the SDK sends in x-site-key header
SITE_KEYS=key1,key2


# ── Collector ────────────────────────────────────────────────────────────────

# noop | turso | telegram | clickhouse | composite  (default: turso)
STORAGE_BACKEND=turso

FLUSH_INTERVAL_MS=5000
MAX_QUEUE_SIZE=1000
CORS_ORIGINS=*

COLLECTOR_PORT=4210


# ── Query API ────────────────────────────────────────────────────────────────

QUERY_API_PORT=4211

# Optional — leave blank for open read access (safe for same-origin dashboards)
QUERY_API_KEY=


# ── Dashboard ────────────────────────────────────────────────────────────────

# Single entry point — nginx proxies /api/* → query-api and /e → collector
DASHBOARD_PORT=4212

# Baked into the Vite build.
#   /api  → proxied by dashboard nginx (default, same-origin, no CORS)
#   http://host:4211  → direct access (split-origin deploy only)
VITE_QUERY_API_URL=/api

# SDK collector endpoint when pointing at the dashboard origin:
#   new Analytics({ endpoint: 'http://yourhost/e', siteKey: '...' })
# This avoids CORS entirely — the SDK never talks to a different origin.


# ── Processor ────────────────────────────────────────────────────────────────

PROCESSOR_INTERVAL_MS=30000


# ── ClickHouse (only needed with --profile clickhouse) ───────────────────────

CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=


# ── Alerts (optional) ────────────────────────────────────────────────────────

# Telegram bot that will send alert messages
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Fire error-spike alert when a single processor batch contains >= N new errors (default: 5)
ALERT_ERROR_THRESHOLD=5

# Cooldown between repeated alerts of the same type per site, in ms (default: 3600000 = 1 h)
ALERT_COOLDOWN_MS=3600000

# How many consecutive empty batches before a traffic-drop alert fires (default: 2)
ALERT_TRAFFIC_DROP_SKIP=2


# ── Optional: Telegram storage ───────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
